# 复制为 .env 后，普通 docker compose up -d 会自动启动 MCP 和自动化工具
COMPOSE_PROFILES=mcp

# ARL MCP 配置
ARL_TOKEN=change-me
ARL_ALLOWED_SUFFIXES=example.com
ARL_BASE_URL=https://web:443
ARL_VERIFY_TLS=false
ARL_TIMEOUT=30

# MCP 服务配置
MCP_TRANSPORT=sse
MCP_DATA_DIR=/data
MCP_MAX_PAGE_SIZE=500
MCP_DEFAULT_MAX_PAGES=10

# 自动化工具 sidecar
AUTO_TOOLS_BASE_URL=http://arl-auto-tools:8770
AUTO_TOOLS_ALLOWED_SUFFIXES=example.com
AUTO_TOOLS_DATA_DIR=/data/auto-tools
AUTO_TOOLS_MAX_URLS=1000
AUTO_TOOLS_TIMEOUT=1800
AUTO_TOOLS_HTTPX_RATE_LIMIT=50
AUTO_TOOLS_NUCLEI_RATE_LIMIT=20
AUTO_TOOLS_NUCLEI_CONCURRENCY=10
AUTO_TOOLS_KATANA_DEPTH=2
