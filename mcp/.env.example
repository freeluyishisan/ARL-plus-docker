# ARL Web API 地址
# Docker Compose 内部默认用 https://web:443
# 宿主机本地 stdio 调试一般用 https://127.0.0.1:5003
ARL_BASE_URL=https://web:443

# ARL API Key，不要提交真实值
ARL_TOKEN=change-me

# 允许 AI 创建扫描任务的范围，多个用英文逗号分隔
# 示例：example.com,example.cn,10.0.0.0/8
ARL_ALLOWED_SUFFIXES=example.com

# ARL 默认自签证书，保持 false
ARL_VERIFY_TLS=false
ARL_TIMEOUT=30

# sse: Docker sidecar 暴露 http://127.0.0.1:8765/sse
# stdio: 本地客户端直接拉起 python server.py
MCP_TRANSPORT=sse
MCP_HOST=0.0.0.0
MCP_PORT=8765
MCP_NAME=arl-plus-mcp
